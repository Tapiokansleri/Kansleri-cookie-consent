#: kansleri-cookie-consent.php
msgid "We use cookies"
msgstr "Käytämme evästeitä"

#: kansleri-cookie-consent.php
msgid "We use cookies to improve your experience and analyze site traffic. Choose which cookies you allow."
msgstr "Käytämme evästeitä parantaaksemme käyttökokemustasi ja analysoidaksemme sivuston liikennettä. Valitse mitkä evästeet sallit."

#: kansleri-cookie-consent.php
msgid "Accept all"
msgstr "Hyväksy kaikki"

#: kansleri-cookie-consent.php
msgid "Reject all"
msgstr "Hylkää kaikki"

#: kansleri-cookie-consent.php
msgid "Customize"
msgstr "Muokkaa"

#: kansleri-cookie-consent.php
msgid "Save preferences"
msgstr "Tallenna valinnat"

#: kansleri-cookie-consent.php
msgid "Necessary"
msgstr "Välttämättömät"

#: kansleri-cookie-consent.php
msgid "Required for the website to function. Cannot be disabled."
msgstr "Välttämättömiä sivuston toiminnalle. Ei voi poistaa käytöstä."

#: kansleri-cookie-consent.php
msgid "Analytics"
msgstr "Analytiikka"

#: kansleri-cookie-consent.php
msgid "Help us understand how visitors interact with the website."
msgstr "Auttavat meitä ymmärtämään, miten kävijät käyttävät sivustoa."

#: kansleri-cookie-consent.php
msgid "Marketing"
msgstr "Markkinointi"

#: kansleri-cookie-consent.php
msgid "Used to deliver relevant advertisements and track campaigns."
msgstr "Käytetään kohdistettujen mainosten näyttämiseen ja kampanjoiden seurantaan."

#: kansleri-cookie-consent.php
msgid "Preferences"
msgstr "Mieltymykset"

#: kansleri-cookie-consent.php
msgid "Remember your settings and preferences for a better experience."
msgstr "Muistavat asetuksesi ja mieltymyksesi paremman käyttökokemuksen takaamiseksi."

#: kansleri-cookie-consent.php
msgid "Settings"
msgstr "Asetukset"

#: kansleri-cookie-consent.php
msgid "Kansleri Cookie Consent is now active. Next steps: %1$s to discover cookies and %2$s to review banner and consent settings."
msgstr "Kansleri Cookie Consent on nyt aktiivinen. Seuraavat vaiheet: %1$s löytääksesi evästeet ja %2$s tarkistaaksesi bannerin ja suostumusasetukset."

#: kansleri-cookie-consent.php
msgid "Scan cookies"
msgstr "Skannaa evästeet"

#: kansleri-cookie-consent.php
msgid "review settings"
msgstr "tarkista asetukset"

#: kansleri-cookie-consent.php
msgid "Cookie Consent: %1$d cookie(s) are missing descriptions: %2$s. %3$s to add them."
msgstr "Evästesuostumus: %1$d evästeeltä puuttuu kuvaus: %2$s. %3$s lisätäksesi ne."

#: kansleri-cookie-consent.php
msgid "Go to Cookies tab"
msgstr "Siirry Evästeet-välilehteen"

#: includes/class-admin.php
msgid "Cookie Consent"
msgstr "Evästesuostumus"

#: includes/class-admin.php
msgid "Settings saved."
msgstr "Asetukset tallennettu."

#: includes/class-admin.php
msgid "An error occurred."
msgstr "Tapahtui virhe."

#: includes/class-admin.php
msgid "Scanning..."
msgstr "Skannataan..."

#: includes/class-admin.php
msgid "Scan complete."
msgstr "Skannaus valmis."

#: includes/class-admin.php
msgid "No new cookies found."
msgstr "Uusia evästeitä ei löytynyt."

#: includes/class-admin.php
msgid "Remove this cookie?"
msgstr "Poista tämä eväste?"

#: includes/class-admin.php
msgid "Scan Cookies"
msgstr "Skannaa evästeet"

#: includes/class-admin.php
msgid "Invalid JSON format. Please import a valid cookie array."
msgstr "Virheellinen JSON-muoto. Tuo kelvollinen eväste-JSON."

#: includes/class-admin.php
msgid "Cookies imported into the table. Save cookies to persist changes."
msgstr "Evästeet tuotu taulukkoon. Tallenna evästeet säilyttääksesi muutokset."

#: includes/class-admin.php
msgid "No valid cookies found in imported JSON."
msgstr "Tuodusta JSONista ei löytynyt kelvollisia evästeitä."

#: includes/class-admin.php
msgid "No cookie rows available to export."
msgstr "Ei vietäviä evästerivejä."

#: includes/class-admin.php
msgid "AI prompt copied to clipboard."
msgstr "AI-kehote kopioitu leikepöydälle."

#: includes/class-admin.php
msgid "Could not copy prompt automatically. Copy it manually from the prompt dialog."
msgstr "Kehotetta ei voitu kopioida automaattisesti. Kopioi se manuaalisesti kehoteikkunasta."

#: includes/class-admin.php
msgid "All cookies are done! Every cookie has a description."
msgstr "Kaikki evästeet valmiita! Jokaisella evästeellä on kuvaus."

